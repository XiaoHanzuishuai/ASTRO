<script is:inline>
// 等待页面完全加载后执行
window.addEventListener("DOMContentLoaded", function() {
  console.log("✅ 页面加载完成，开始初始化 Live2D 看板娘");

  // 通用资源加载函数
  function loadResource(url, type, callback) {
    const elem = type === "css"
      ? Object.assign(document.createElement("link"), { rel: "stylesheet", href: url })
      : Object.assign(document.createElement("script"), { src: url, async: false });
    
    elem.onload = () => {
      console.log(`✅ 加载成功: ${url}`);
      callback();
    };
    elem.onerror = (e) => console.error(`❌ 加载失败: ${url}`, e);
    document.head.appendChild(elem);
  }

  // 按顺序加载资源并初始化
  loadResource(
    "https://fastly.jsdelivr.net/npm/live2d-widget@3.1.4/dist/waifu.css",
    "css",
    () => loadResource(
      "https://fastly.jsdelivr.net/npm/live2d-widget@3.1.4/lib/live2d.min.js",
      "js",
      () => loadResource(
        "https://fastly.jsdelivr.net/npm/live2d-widget@3.1.4/dist/waifu-tips.js",
        "js",
        () => {
          console.log("🚀 初始化看板娘");
          window.initWidget({
            // 提示语配置
            waifuPath: "https://fastly.jsdelivr.net/npm/live2d-widget@3.1.4/dist/waifu-tips.json",
            // 模型API（先用官方稳定在线模型，确保能正常显示）
            apiPath: "https://live2d.fghrsh.net/api/",
            // 等看板娘正常显示后，取消下面的注释，替换成你的本地模型
            // modelPath: "/live2d-widget/model/xch001_01/",
            // 工具栏配置
            tools: ["hitokoto", "switch-model", "photo", "quit"],
            // 可拖拽
            drag: true,
            // 开启调试日志，方便排查问题
            logLevel: "debug",
            // 延长加载超时时间
            loadTimeout: 20000
          });
        }
      )
    )
  );
});
</script>
